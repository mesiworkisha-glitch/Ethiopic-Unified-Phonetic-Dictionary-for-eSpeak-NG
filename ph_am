// --- Ethiopic Punctuation ---

phoneme ፣  // Ethiopic Comma
  vowel n/a
  length 150
  pause
end phoneme

phoneme ፤  // Ethiopic Semicolon
  vowel n/a
  length 200
  pause
end phoneme

phoneme ፡
  vcl stop
  pause
  length 40  // Short separator pause
endphoneme

// --- Standard/Western Punctuation ---

phoneme .  // Period
  vowel n/a
  length 20
  pause
end phoneme

phoneme ,  // Comma
  vowel n/a
  length 150
  pause
end phoneme

phoneme /  // Slash (Critical for your abbreviations)
  vowel n/a
  length 30    // Very short, almost no pause
end phoneme

phoneme (  // Left Parenthesis
  vowel n/a
  pause
end phoneme

phoneme )  // Right Parenthesis
  vowel n/a
  pause
end phoneme

phoneme ?  // Question Mark
  vowel n/a
  length 300
  pause
  pitch 20    // Slight rise in pitch for questions
end phoneme

// Base Palatalized K (Single)
phoneme k'
  vcl stop
  liquid
  source  k/k_soft
  length  140
  output  k j
endphoneme

// Geminated Palatalized K (Double/Strong)
phoneme kk'
  vcl stop
  liquid
  source  k/k_hard
  length  220  // Increased length for gemination
  pause   40   // Slight tension/hold before release
  output  k j
endphoneme

// Left Double Angle Quote « (kafet_t'ykys)
phoneme «
  type  punctuation
  pause 120    // Pre-speech pause
  intonation boundary
endphoneme

// Right Double Angle Quote » (zy_g_t'ykys)
phoneme »
  type  punctuation
  pause 80     // Brief post-speech pause
  intonation fall
endphoneme

// Inverted Exclamation ¡ (tymyr_t@_sy_laq)
phoneme ¡
  type  punctuation
  intonation raise // Sarcasm/Irony often uses a rising pitch
  pause 40
endphoneme

phoneme ፡
  vcl stop
  pause
endphoneme